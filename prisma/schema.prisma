// ===========================
// 2. INSURANCE / TPA CLAIMS
// ===========================

model InsuranceProvider {
  id            String   @id @default(cuid())
  name          String
  code          String   @unique
  type          String   // TPA, DIRECT, GOVERNMENT
  contactPerson String?
  phone         String?
  email         String?
  address       String?
  website       String?
  panelRate     Decimal? @db.Decimal(5, 2) // discount percentage
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  policies InsurancePolicy[]
  claims   InsuranceClaim[]

  @@map("insurance_providers")
}

model InsurancePolicy {
  id               String   @id @default(cuid())
  patientId        String
  providerId       String
  policyNumber     String
  groupNumber      String?
  membershipId     String?
  holderName       String
  relationship     String   @default("SELF")
  coverageType     String   // INDIVIDUAL, FAMILY, GROUP
  coverageAmount   Decimal  @db.Decimal(12, 2)
  usedAmount       Decimal  @db.Decimal(12, 2) @default(0)
  balanceAmount    Decimal  @db.Decimal(12, 2)
  startDate        DateTime
  endDate          DateTime
  copayPercentage  Decimal? @db.Decimal(5, 2)
  deductible       Decimal? @db.Decimal(10, 2)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  patient  Patient           @relation(fields: [patientId], references: [id])
  provider InsuranceProvider @relation(fields: [providerId], references: [id])
  claims   InsuranceClaim[]

  @@index([patientId])
  @@index([policyNumber])
  @@map("insurance_policies")
}

model InsuranceClaim {
  id                 String      @id @default(cuid())
  claimNo            String      @unique
  patientId          String
  providerId         String
  policyId           String
  invoiceId          String?
  admissionId        String?
  claimType          String      // PRE_AUTH, CASHLESS, REIMBURSEMENT
  claimAmount        Decimal     @db.Decimal(12, 2)
  approvedAmount     Decimal?    @db.Decimal(12, 2)
  settledAmount      Decimal?    @db.Decimal(12, 2)
  rejectionReason    String?
  diagnosis          String
  treatmentDetails   String?
  admissionDate      DateTime?
  dischargeDate      DateTime?
  status             ClaimStatus @default(DRAFT)
  submittedAt        DateTime?
  approvedAt         DateTime?
  settledAt          DateTime?
  submittedBy        String?
  approvedBy         String?
  notes              String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  patient  Patient           @relation(fields: [patientId], references: [id])
  provider InsuranceProvider @relation(fields: [providerId], references: [id])
  policy   InsurancePolicy   @relation(fields: [policyId], references: [id])
  documents ClaimDocument[]

  @@index([patientId])
  @@index([status])
  @@map("insurance_claims")
}

model ClaimDocument {
  id        String   @id @default(cuid())
  claimId   String
  title     String
  fileType  String
  filePath  String
  uploadedBy String
  createdAt DateTime @default(now())

  claim InsuranceClaim @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@map("claim_documents")
}

model PreAuthorization {
  id               String   @id @default(cuid())
  preAuthNo        String   @unique
  patientId        String
  providerId       String
  policyNumber     String
  treatmentType    String
  estimatedCost    Decimal  @db.Decimal(12, 2)
  approvedAmount   Decimal? @db.Decimal(12, 2)
  diagnosis        String
  plannedProcedure String?
  expectedLOS      Int?     // Length of Stay in days
  status           String   @default("PENDING") // PENDING, APPROVED, REJECTED, EXPIRED
  validFrom        DateTime?
  validUntil       DateTime?
  approvalCode     String?
  rejectionReason  String?
  requestedBy      String
  requestedAt      DateTime @default(now())
  respondedAt      DateTime?
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([patientId])
  @@index([status])
  @@map("pre_authorizations")
}

// ===========================
// 3. OPERATION THEATRE MANAGEMENT
// ===========================

model OperationTheatre {
  id           String   @id @default(cuid())
  name         String   @unique
  code         String   @unique
  location     String?
  type         String   // GENERAL, CARDIAC, NEURO, ORTHO, ENT, OPHTHAL, EMERGENCY
  equipment    String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  surgeries Surgery[]

  @@map("operation_theatres")
}

model Surgery {
  id                  String        @id @default(cuid())
  surgeryNo           String        @unique
  patientId           String
  otId                String
  primarySurgeonId    String
  anesthetistId       String?
  admissionId         String?
  scheduledDate       DateTime
  scheduledStartTime  String
  scheduledEndTime    String
  actualStartTime     DateTime?
  actualEndTime       DateTime?
  surgeryType         String        // ELECTIVE, EMERGENCY, DAY_CARE
  procedureName       String
  procedureCode       String?
  laterality          String?       // LEFT, RIGHT, BILATERAL, NA
  diagnosis           String
  preOpDiagnosis      String?
  postOpDiagnosis     String?
  anesthesiaType      String?       // GENERAL, REGIONAL, LOCAL, SPINAL, EPIDURAL
  estimatedDuration   Int?          // minutes
  actualDuration      Int?
  complications       String?
  bloodLossML         Int?
  findings            String?
  operativeNotes      String?
  postOpInstructions  String?
  status              SurgeryStatus @default(SCHEDULED)
  priority            String        @default("ROUTINE")
  consentObtained     Boolean       @default(false)
  createdBy           String
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  patient    Patient          @relation(fields: [patientId], references: [id])
  theatre    OperationTheatre @relation(fields: [otId], references: [id])
  teamMembers SurgeryTeamMember[]
  checklists  SurgeryChecklist[]

  @@index([scheduledDate])
  @@index([status])
  @@map("surgeries")
}

model SurgeryTeamMember {
  id        String @id @default(cuid())
  surgeryId String
  userId    String
  role      String // PRIMARY_SURGEON, ASSISTANT_SURGEON, ANESTHETIST, SCRUB_NURSE, CIRCULATING_NURSE

  surgery Surgery @relation(fields: [surgeryId], references: [id], onDelete: Cascade)

  @@map("surgery_team_members")
}

model SurgeryChecklist {
  id          String    @id @default(cuid())
  surgeryId   String
  phase       String    // PRE_OP, SIGN_IN, TIME_OUT, SIGN_OUT
  item        String
  isCompleted Boolean   @default(false)
  completedBy String?
  completedAt DateTime?
  notes       String?

  surgery Surgery @relation(fields: [surgeryId], references: [id], onDelete: Cascade)

  @@map("surgery_checklists")
}

// ===========================
// 4. EMERGENCY MODULE
// ===========================

model EmergencyVisit {
  id                  String      @id @default(cuid())
  visitNo             String      @unique
  patientId           String?
  // Walk-in fields (patient may not be registered yet)
  walkInName          String?
  walkInAge           Int?
  walkInGender        String?
  walkInPhone         String?
  arrivalMode         String      @default("WALK_IN") // WALK_IN, AMBULANCE, POLICE, REFERRED
  arrivalTime         DateTime    @default(now())
  triageLevel         TriageLevel @default(URGENT)
  triageNotes         String?
  triagedBy           String?
  chiefComplaint      String
  injuryType          String?     // TRAUMA, MEDICAL, SURGICAL, OBSTETRIC, PEDIATRIC
  vitalSigns          String?     // JSON: BP, HR, RR, Temp, SpO2
  consciousnessLevel  String?     // ALERT, VERBAL, PAIN, UNRESPONSIVE (AVPU)
  primaryAssessment   String?
  treatmentGiven      String?
  diagnosis           String?
  disposition         String      @default("UNDER_OBSERVATION") // UNDER_OBSERVATION, ADMITTED, DISCHARGED, TRANSFERRED, DECEASED, LAMA
  dispositionTime     DateTime?
  attendingDoctorId   String?
  bedAssigned         String?
  isStabilized        Boolean     @default(false)
  notes               String?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  patient Patient? @relation(fields: [patientId], references: [id])

  @@index([arrivalTime])
  @@index([triageLevel])
  @@index([disposition])
  @@map("emergency_visits")
}

// ===========================
// 6. BLOOD BANK MANAGEMENT
// ===========================

model BloodDonor {
  id             String     @id @default(cuid())
  donorNo        String     @unique
  firstName      String
  lastName       String
  dateOfBirth    DateTime
  gender         Gender
  bloodGroup     BloodGroup
  phone          String
  email          String?
  address        String?
  lastDonationDate DateTime?
  totalDonations Int        @default(0)
  isDeferredUntil DateTime?
  deferralReason  String?
  isActive       Boolean    @default(true)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  donations BloodDonation[]

  @@index([bloodGroup])
  @@map("blood_donors")
}

model BloodDonation {
  id            String   @id @default(cuid())
  donationNo    String   @unique
  donorId       String
  donationDate  DateTime @default(now())
  bagNumber     String   @unique
  bloodGroup    BloodGroup
  volumeML      Int      @default(450)
  hemoglobin    Decimal? @db.Decimal(4, 1)
  bloodPressure String?
  isScreened    Boolean  @default(false)
  screeningResult String? // PASS, FAIL
  screeningNotes  String?
  collectedBy   String
  notes         String?
  createdAt     DateTime @default(now())

  donor     BloodDonor     @relation(fields: [donorId], references: [id])
  inventory BloodInventory?

  @@map("blood_donations")
}

model BloodInventory {
  id            String         @id @default(cuid())
  bagNumber     String         @unique
  donationId    String?        @unique
  bloodGroup    BloodGroup
  component     BloodComponent @default(WHOLE_BLOOD)
  volumeML      Int
  collectionDate DateTime
  expiryDate    DateTime
  status        String         @default("AVAILABLE") // AVAILABLE, RESERVED, ISSUED, EXPIRED, DISCARDED
  storageLocation String?
  temperature   Decimal?       @db.Decimal(4, 1)
  crossMatchedFor String?
  notes         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  donation BloodDonation? @relation(fields: [donationId], references: [id])
  issuances BloodIssuance[]

  @@index([bloodGroup, component, status])
  @@index([expiryDate])
  @@map("blood_inventory")
}

model BloodRequest {
  id            String      @id @default(cuid())
  requestNo     String      @unique
  patientId     String
  bloodGroup    BloodGroup
  component     BloodComponent @default(WHOLE_BLOOD)
  unitsRequired Int
  unitsIssued   Int         @default(0)
  reason        String
  urgency       String      @default("ROUTINE") // STAT, URGENT, ROUTINE
  requiredDate  DateTime
  requestedBy   String
  status        String      @default("PENDING") // PENDING, CROSS_MATCHED, READY, PARTIALLY_ISSUED, ISSUED, CANCELLED
  crossMatchResult String?
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  patient   Patient         @relation(fields: [patientId], references: [id])
  issuances BloodIssuance[]

  @@index([patientId])
  @@index([status])
  @@map("blood_requests")
}

model BloodIssuance {
  id          String   @id @default(cuid())
  requestId   String
  inventoryId String
  issuedBy    String
  issuedAt    DateTime @default(now())
  returnedAt  DateTime?
  isReturned  Boolean  @default(false)
  notes       String?

  request   BloodRequest   @relation(fields: [requestId], references: [id])
  inventory BloodInventory @relation(fields: [inventoryId], references: [id])

  @@map("blood_issuances")
}

// ===========================
// 7. QUEUE TOKEN MANAGEMENT
// ===========================

model QueueToken {
  id            String   @id @default(cuid())
  tokenNo       Int
  patientId     String?
  patientName   String?
  departmentId  String?
  doctorId      String?
  counterNo     String?
  serviceType   String   @default("OPD") // OPD, PHARMACY, LAB, RADIOLOGY, BILLING
  status        String   @default("WAITING") // WAITING, SERVING, COMPLETED, SKIPPED, CANCELLED
  priority      String   @default("NORMAL") // NORMAL, PRIORITY, EMERGENCY
  calledAt      DateTime?
  servedAt      DateTime?
  completedAt   DateTime?
  estimatedWait Int?     // minutes
  date          DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  patient Patient? @relation(fields: [patientId], references: [id])

  @@index([date, serviceType, status])
  @@map("queue_tokens")
}

model QueueCounter {
  id          String  @id @default(cuid())
  counterNo   String  @unique
  name        String
  serviceType String  // OPD, PHARMACY, LAB, RADIOLOGY, BILLING
  location    String?
  isActive    Boolean @default(true)
  currentToken Int?
  assignedTo  String?

  @@map("queue_counters")
}

// ===========================
// 11. TELEMEDICINE
// ===========================

model TeleconsultSession {
  id              String   @id @default(cuid())
  sessionNo       String   @unique
  patientId       String
  doctorId        String
  appointmentId   String?
  scheduledDate   DateTime
  scheduledTime   String
  duration        Int?     // minutes
  actualStartTime DateTime?
  actualEndTime   DateTime?
  meetingLink     String?
  meetingPlatform String   @default("BUILT_IN") // BUILT_IN, ZOOM, GOOGLE_MEET, TEAMS
  chiefComplaint  String?
  notes           String?
  prescription    String?
  diagnosis       String?
  followUpDate    DateTime?
  recordingPath   String?
  status          String   @default("SCHEDULED") // SCHEDULED, WAITING, IN_PROGRESS, COMPLETED, CANCELLED, NO_SHOW
  cancelReason    String?
  rating          Int?
  feedback        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  patient Patient @relation(fields: [patientId], references: [id])

  @@index([scheduledDate])
  @@index([status])
  @@map("teleconsult_sessions")
}

// ===========================
// 12. DIETARY MANAGEMENT
// ===========================

model DietPlan {
  id             String   @id @default(cuid())
  patientId      String
  admissionId    String?
  dietType       String   // REGULAR, DIABETIC, LOW_SODIUM, RENAL, LIQUID, SOFT, NPO, CUSTOM
  allergies      String?
  restrictions   String?
  calories       Int?
  proteinGrams   Int?
  carbGrams      Int?
  fatGrams       Int?
  specialInstructions String?
  prescribedBy   String
  startDate      DateTime @default(now())
  endDate        DateTime?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  patient    Patient     @relation(fields: [patientId], references: [id])
  mealOrders MealOrder[]

  @@index([patientId])
  @@map("diet_plans")
}

model MealOrder {
  id          String   @id @default(cuid())
  dietPlanId  String
  mealType    String   // BREAKFAST, LUNCH, SNACK, DINNER
  date        DateTime
  items       String   // JSON array of menu items
  specialNotes String?
  status      String   @default("PENDING") // PENDING, PREPARING, DELIVERED, CANCELLED
  preparedBy  String?
  deliveredBy String?
  deliveredAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  dietPlan DietPlan @relation(fields: [dietPlanId], references: [id])

  @@map("meal_orders")
}

// ===========================
// 13. CSSD - CENTRAL STERILE SUPPLY
// ===========================

model InstrumentSet {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  department  String?
  items       String   // JSON list of instruments
  totalItems  Int
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  batches SterilizationBatch[]

  @@map("instrument_sets")
}

model SterilizationBatch {
  id              String              @id @default(cuid())
  batchNo         String              @unique
  instrumentSetId String
  method          String              // AUTOCLAVE, ETO, PLASMA, CHEMICAL
  cycleNumber     String?
  machineId       String?
  loadDate        DateTime            @default(now())
  sterilizationDate DateTime?
  expiryDate      DateTime?
  temperature     Decimal?            @db.Decimal(5, 1)
  pressure        Decimal?            @db.Decimal(5, 2)
  duration        Int?                // minutes
  biIndicator     String?             // PASS, FAIL
  chemIndicator   String?             // PASS, FAIL
  status          SterilizationStatus @default(PENDING)
  issuedTo        String?
  issuedAt        DateTime?
  returnedAt      DateTime?
  processedBy     String
  verifiedBy      String?
  notes           String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  instrumentSet InstrumentSet @relation(fields: [instrumentSetId], references: [id])

  @@index([status])
  @@map("sterilization_batches")
}

// ===========================
// 14. AMBULANCE MANAGEMENT
// ===========================

model Ambulance {
  id              String   @id @default(cuid())
  vehicleNumber   String   @unique
  type            String   // BLS, ALS, PATIENT_TRANSPORT, NEONATAL
  make            String?
  model           String?
  year            Int?
  driverName      String?
  driverPhone     String?
  paramedicName   String?
  paramedicPhone  String?
  gpsTrackingId   String?
  insuranceExpiry DateTime?
  fitnessExpiry   DateTime?
  lastServiceDate DateTime?
  status          AmbulanceStatus @default(AVAILABLE)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  dispatches AmbulanceDispatch[]

  @@map("ambulances")
}

model AmbulanceDispatch {
  id              String    @id @default(cuid())
  dispatchNo      String    @unique
  ambulanceId     String
  patientName     String?
  patientPhone    String?
  pickupAddress   String
  dropAddress     String?
  callTime        DateTime  @default(now())
  dispatchTime    DateTime?
  arrivalTime     DateTime?
  hospitalArrival DateTime?
  tripType        String    @default("EMERGENCY") // EMERGENCY, TRANSFER, PICKUP, RETURN
  priority        String    @default("URGENT")
  distance        Decimal?  @db.Decimal(8, 2) // km
  chiefComplaint  String?
  vitalsDuringTransit String?
  treatmentGiven  String?
  status          String    @default("DISPATCHED") // DISPATCHED, EN_ROUTE, AT_SCENE, TRANSPORTING, COMPLETED, CANCELLED
  completedAt     DateTime?
  dispatchedBy    String
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  ambulance Ambulance @relation(fields: [ambulanceId], references: [id])

  @@index([status])
  @@index([callTime])
  @@map("ambulance_dispatches")
}

// ===========================
// 15. PHYSIOTHERAPY
// ===========================

model TherapyPlan {
  id               String   @id @default(cuid())
  planNo           String   @unique
  patientId        String
  referredBy       String?
  therapistId      String?
  diagnosis        String
  condition        String?
  goals            String?  // Short-term and long-term goals
  treatmentProtocol String?
  frequency        String?  // e.g., "3 times/week"
  totalSessions    Int?
  completedSessions Int     @default(0)
  startDate        DateTime @default(now())
  endDate          DateTime?
  status           String   @default("ACTIVE") // ACTIVE, COMPLETED, DISCONTINUED, ON_HOLD
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  patient  Patient          @relation(fields: [patientId], references: [id])
  sessions TherapySession[]

  @@index([patientId])
  @@map("therapy_plans")
}

model TherapySession {
  id            String   @id @default(cuid())
  therapyPlanId String
  sessionNo     Int
  sessionDate   DateTime
  duration      Int?     // minutes
  exercises     String?  // JSON array of exercises
  modalities    String?  // e.g., Ultrasound, TENS, Heat, Ice
  painLevel     Int?     // 0-10 scale
  progressNotes String?
  outcome       String?  // IMPROVED, SAME, DECLINED
  nextGoals     String?
  performedBy   String
  status        String   @default("SCHEDULED") // SCHEDULED, COMPLETED, CANCELLED, NO_SHOW
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  therapyPlan TherapyPlan @relation(fields: [therapyPlanId], references: [id])

  @@map("therapy_sessions")
}
