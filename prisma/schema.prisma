generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===========================
// ENUMS
// ===========================

enum Role {
  ADMIN
  DOCTOR
  NURSE
  RECEPTIONIST
  PHARMACIST
  LAB_TECHNICIAN
  RADIOLOGIST
  ACCOUNTANT
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum BloodGroup {
  A_POSITIVE
  A_NEGATIVE
  B_POSITIVE
  B_NEGATIVE
  AB_POSITIVE
  AB_NEGATIVE
  O_POSITIVE
  O_NEGATIVE
}

enum MaritalStatus {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED
}

enum AppointmentStatus {
  SCHEDULED
  CHECKED_IN
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum AdmissionStatus {
  ADMITTED
  DISCHARGED
  TRANSFERRED
  DECEASED
}

enum BedStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
  RESERVED
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  CASH
  CARD
  UPI
  INSURANCE
  BANK_TRANSFER
  CHEQUE
}

enum OrderStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PurchaseOrderStatus {
  DRAFT
  SUBMITTED
  APPROVED
  RECEIVED
  CANCELLED
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum PayrollStatus {
  DRAFT
  PROCESSED
  PAID
}

enum TriageLevel {
  RESUSCITATION
  EMERGENT
  URGENT
  LESS_URGENT
  NON_URGENT
}

enum ClaimStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  PARTIALLY_APPROVED
  REJECTED
  SETTLED
  APPEALED
}

enum SurgeryStatus {
  SCHEDULED
  PREP
  IN_PROGRESS
  RECOVERY
  COMPLETED
  CANCELLED
}

enum BloodComponent {
  WHOLE_BLOOD
  PACKED_RBC
  PLATELET
  PLASMA
  CRYOPRECIPITATE
}

enum SterilizationStatus {
  PENDING
  IN_PROGRESS
  STERILIZED
  ISSUED
  RETURNED
}

enum AmbulanceStatus {
  AVAILABLE
  DISPATCHED
  EN_ROUTE
  AT_SCENE
  RETURNING
  MAINTENANCE
}

// ===========================
// AUTHENTICATION & USERS
// ===========================

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  name      String
  role      Role      @default(RECEPTIONIST)
  isActive  Boolean   @default(true)
  avatar    String?
  phone     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  employee Employee?
  doctor   Doctor?
  accounts Account[]
  sessions Session[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ===========================
// HOSPITAL CONFIGURATION
// ===========================

model Hospital {
  id        String   @id @default(cuid())
  name      String
  address   String
  city      String
  state     String
  zipCode   String
  phone     String
  email     String
  website   String?
  logo      String?
  taxId     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("hospitals")
}

model Department {
  id          String   @id @default(cuid())
  name        String   @unique
  code        String   @unique
  description String?
  isActive    Boolean  @default(true)
  headId      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  doctors   Doctor[]
  employees Employee[]
  wards     Ward[]

  @@map("departments")
}

// ===========================
// PATIENT MANAGEMENT
// ===========================

model Patient {
  id                String        @id @default(cuid())
  mrn               String        @unique
  firstName         String
  lastName          String
  dateOfBirth       DateTime
  gender            Gender
  bloodGroup        BloodGroup?
  maritalStatus     MaritalStatus?
  phone             String
  email             String?
  address           String
  city              String
  state             String
  zipCode           String
  emergencyName     String?
  emergencyPhone    String?
  emergencyRelation String?
  insuranceProvider String?
  insurancePolicyNo String?
  allergies         String?
  chronicConditions String?
  photo             String?
  isActive          Boolean       @default(true)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  deletedAt         DateTime?

  appointments    Appointment[]
  consultations   Consultation[]
  admissions      Admission[]
  invoices        Invoice[]
  prescriptions   Prescription[]
  labOrders       LabOrder[]
  radiologyOrders RadiologyOrder[]
  vitals          Vitals[]
  documents       PatientDocument[]
  medicalRecords  MedicalRecord[]
  insurancePolicies InsurancePolicy[]
  insuranceClaims InsuranceClaim[]
  emergencyVisits EmergencyVisit[]
  surgeries       Surgery[]
  bloodRequests   BloodRequest[]
  queueTokens     QueueToken[]
  teleconsults    TeleconsultSession[]
  dietPlans       DietPlan[]
  therapyPlans    TherapyPlan[]

  @@index([firstName, lastName])
  @@index([phone])
  @@map("patients")
}

model PatientDocument {
  id         String   @id @default(cuid())
  patientId  String
  title      String
  type       String
  filePath   String
  uploadedBy String
  createdAt  DateTime @default(now())

  patient Patient @relation(fields: [patientId], references: [id])

  @@map("patient_documents")
}

// ===========================
// DOCTOR / STAFF
// ===========================

model Doctor {
  id              String   @id @default(cuid())
  userId          String   @unique
  specialization  String
  qualification   String
  licenseNumber   String   @unique
  departmentId    String
  consultationFee Decimal  @db.Decimal(10, 2)
  isAvailable     Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user       User       @relation(fields: [userId], references: [id])
  department Department @relation(fields: [departmentId], references: [id])

  appointments  Appointment[]
  consultations Consultation[]
  admissions    Admission[]
  schedules     DoctorSchedule[]

  @@map("doctors")
}

model DoctorSchedule {
  id           String  @id @default(cuid())
  doctorId     String
  dayOfWeek    Int
  startTime    String
  endTime      String
  slotDuration Int     @default(15)
  isActive     Boolean @default(true)

  doctor Doctor @relation(fields: [doctorId], references: [id])

  @@unique([doctorId, dayOfWeek])
  @@map("doctor_schedules")
}

// ===========================
// APPOINTMENT SCHEDULING
// ===========================

model Appointment {
  id            String            @id @default(cuid())
  appointmentNo String            @unique
  patientId     String
  doctorId      String
  departmentId  String?
  date          DateTime
  startTime     String
  endTime       String
  status        AppointmentStatus @default(SCHEDULED)
  type          String            @default("CONSULTATION")
  reason        String?
  notes         String?
  tokenNumber   Int?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  patient      Patient       @relation(fields: [patientId], references: [id])
  doctor       Doctor        @relation(fields: [doctorId], references: [id])
  consultation Consultation?

  @@index([date, doctorId])
  @@index([patientId])
  @@map("appointments")
}

// ===========================
// OPD - OUTPATIENT
// ===========================

model Vitals {
  id                     String   @id @default(cuid())
  patientId              String
  consultationId         String?
  admissionId            String?
  temperature            Decimal? @db.Decimal(4, 1)
  bloodPressureSystolic  Int?
  bloodPressureDiastolic Int?
  pulseRate              Int?
  respiratoryRate        Int?
  oxygenSaturation       Decimal? @db.Decimal(5, 2)
  weight                 Decimal? @db.Decimal(5, 2)
  height                 Decimal? @db.Decimal(5, 2)
  bmi                    Decimal? @db.Decimal(4, 1)
  notes                  String?
  recordedBy             String
  recordedAt             DateTime @default(now())

  patient      Patient       @relation(fields: [patientId], references: [id])
  consultation Consultation? @relation(fields: [consultationId], references: [id])
  admission    Admission?    @relation(fields: [admissionId], references: [id])

  @@map("vitals")
}

model Consultation {
  id                      String      @id @default(cuid())
  consultationNo          String      @unique
  patientId               String
  doctorId                String
  appointmentId           String?     @unique
  chiefComplaint          String
  historyOfPresentIllness String?
  examination             String?
  diagnosis               String
  icdCodes                String?
  treatmentPlan           String?
  followUpDate            DateTime?
  notes                   String?
  status                  OrderStatus @default(IN_PROGRESS)
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt

  patient     Patient      @relation(fields: [patientId], references: [id])
  doctor      Doctor       @relation(fields: [doctorId], references: [id])
  appointment Appointment? @relation(fields: [appointmentId], references: [id])

  vitals          Vitals[]
  prescriptions   Prescription[]
  labOrders       LabOrder[]
  radiologyOrders RadiologyOrder[]

  @@index([patientId])
  @@index([doctorId])
  @@map("consultations")
}

// ===========================
// IPD - INPATIENT
// ===========================

model Ward {
  id           String     @id @default(cuid())
  name         String     @unique
  departmentId String
  type         String
  totalBeds    Int
  floor        Int
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  department Department @relation(fields: [departmentId], references: [id])
  beds       Bed[]

  @@map("wards")
}

model Bed {
  id        String    @id @default(cuid())
  bedNumber String
  wardId    String
  status    BedStatus @default(AVAILABLE)
  dailyRate Decimal   @db.Decimal(10, 2)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  ward       Ward        @relation(fields: [wardId], references: [id])
  admissions Admission[]

  @@unique([wardId, bedNumber])
  @@map("beds")
}

model Admission {
  id                  String          @id @default(cuid())
  admissionNo         String          @unique
  patientId           String
  doctorId            String
  bedId               String
  admissionDate       DateTime        @default(now())
  dischargeDate       DateTime?
  status              AdmissionStatus @default(ADMITTED)
  admissionReason     String
  diagnosis           String?
  dietInstructions    String?
  specialInstructions String?
  dischargeSummary    String?
  dischargeNotes      String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  patient Patient @relation(fields: [patientId], references: [id])
  doctor  Doctor  @relation(fields: [doctorId], references: [id])
  bed     Bed     @relation(fields: [bedId], references: [id])

  vitals          Vitals[]
  progressNotes   ProgressNote[]
  doctorOrders    DoctorOrder[]
  invoices        Invoice[]
  prescriptions   Prescription[]
  labOrders       LabOrder[]
  radiologyOrders RadiologyOrder[]

  @@index([patientId])
  @@index([status])
  @@map("admissions")
}

model ProgressNote {
  id          String    @id @default(cuid())
  admissionId String
  note        String
  type        String    @default("PROGRESS")
  recordedBy  String
  recordedAt  DateTime  @default(now())

  admission Admission @relation(fields: [admissionId], references: [id])

  @@map("progress_notes")
}

model DoctorOrder {
  id          String      @id @default(cuid())
  admissionId String
  orderType   String
  description String
  priority    String      @default("ROUTINE")
  status      OrderStatus @default(PENDING)
  orderedBy   String
  executedBy  String?
  orderedAt   DateTime    @default(now())
  executedAt  DateTime?
  notes       String?

  admission Admission @relation(fields: [admissionId], references: [id])

  @@map("doctor_orders")
}

// ===========================
// BILLING & INVOICING
// ===========================

model Invoice {
  id             String        @id @default(cuid())
  invoiceNo      String        @unique
  patientId      String
  admissionId    String?
  subtotal       Decimal       @db.Decimal(12, 2)
  taxAmount      Decimal       @db.Decimal(12, 2) @default(0)
  discountAmount Decimal       @db.Decimal(12, 2) @default(0)
  totalAmount    Decimal       @db.Decimal(12, 2)
  paidAmount     Decimal       @db.Decimal(12, 2) @default(0)
  balanceAmount  Decimal       @db.Decimal(12, 2)
  status         InvoiceStatus @default(DRAFT)
  dueDate        DateTime?
  notes          String?
  createdBy      String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  patient   Patient    @relation(fields: [patientId], references: [id])
  admission Admission? @relation(fields: [admissionId], references: [id])

  items    InvoiceItem[]
  payments Payment[]

  @@index([patientId])
  @@index([status])
  @@map("invoices")
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  description String
  category    String
  quantity    Int     @default(1)
  unitPrice   Decimal @db.Decimal(10, 2)
  amount      Decimal @db.Decimal(12, 2)
  referenceId String?

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_items")
}

model Payment {
  id          String        @id @default(cuid())
  paymentNo   String        @unique
  invoiceId   String
  amount      Decimal       @db.Decimal(12, 2)
  method      PaymentMethod
  referenceNo String?
  receivedBy  String
  notes       String?
  paidAt      DateTime      @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
  @@index([paidAt])
  @@map("payments")
}

// ===========================
// PHARMACY MANAGEMENT
// ===========================

model Drug {
  id                   String   @id @default(cuid())
  name                 String
  genericName          String
  brandName            String?
  category             String
  dosageForm           String
  strength             String
  manufacturer         String?
  batchNumber          String?
  barcode              String?
  unitPrice            Decimal  @db.Decimal(10, 2)
  sellingPrice         Decimal  @db.Decimal(10, 2)
  stockQuantity        Int      @default(0)
  reorderLevel         Int      @default(10)
  expiryDate           DateTime?
  storageCondition     String?
  requiresPrescription Boolean  @default(true)
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  prescriptionItems PrescriptionItem[]

  @@index([name])
  @@index([genericName])
  @@map("drugs")
}

model Prescription {
  id             String      @id @default(cuid())
  prescriptionNo String      @unique
  patientId      String
  consultationId String?
  admissionId    String?
  prescribedBy   String
  status         OrderStatus @default(PENDING)
  notes          String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  patient      Patient       @relation(fields: [patientId], references: [id])
  consultation Consultation? @relation(fields: [consultationId], references: [id])
  admission    Admission?    @relation(fields: [admissionId], references: [id])

  items      PrescriptionItem[]
  dispensing Dispensing?

  @@index([patientId])
  @@index([status])
  @@index([consultationId])
  @@map("prescriptions")
}

model PrescriptionItem {
  id             String @id @default(cuid())
  prescriptionId String
  drugId         String
  dosage         String
  frequency      String
  duration       String
  route          String @default("ORAL")
  instructions   String?
  quantity       Int

  prescription Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  drug         Drug         @relation(fields: [drugId], references: [id])

  @@map("prescription_items")
}

model Dispensing {
  id             String   @id @default(cuid())
  prescriptionId String   @unique
  dispensedBy    String
  dispensedAt    DateTime @default(now())
  notes          String?

  prescription Prescription @relation(fields: [prescriptionId], references: [id])

  @@map("dispensings")
}

// ===========================
// LABORATORY MANAGEMENT
// ===========================

model LabTest {
  id             String   @id @default(cuid())
  name           String
  code           String   @unique
  category       String
  description    String?
  sampleType     String
  normalRange    String?
  unit           String?
  price          Decimal  @db.Decimal(10, 2)
  turnaroundTime String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  orderItems LabOrderItem[]

  @@map("lab_tests")
}

model LabOrder {
  id             String      @id @default(cuid())
  orderNo        String      @unique
  patientId      String
  consultationId String?
  admissionId    String?
  orderedBy      String
  priority       String      @default("ROUTINE")
  status         OrderStatus @default(PENDING)
  clinicalInfo   String?
  notes          String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  patient      Patient       @relation(fields: [patientId], references: [id])
  consultation Consultation? @relation(fields: [consultationId], references: [id])
  admission    Admission?    @relation(fields: [admissionId], references: [id])

  items LabOrderItem[]

  @@index([patientId])
  @@index([status])
  @@map("lab_orders")
}

model LabOrderItem {
  id          String      @id @default(cuid())
  labOrderId  String
  labTestId   String
  status      OrderStatus @default(PENDING)
  result      String?
  resultValue Decimal?    @db.Decimal(10, 4)
  unit        String?
  normalRange String?
  isAbnormal  Boolean?
  performedBy String?
  performedAt DateTime?
  verifiedBy  String?
  verifiedAt  DateTime?
  notes       String?

  labOrder LabOrder @relation(fields: [labOrderId], references: [id], onDelete: Cascade)
  labTest  LabTest  @relation(fields: [labTestId], references: [id])

  @@map("lab_order_items")
}

// ===========================
// RADIOLOGY MANAGEMENT
// ===========================

model Modality {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  description String?
  roomNumber  String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  examTypes RadiologyExamType[]

  @@map("modalities")
}

model RadiologyExamType {
  id          String   @id @default(cuid())
  modalityId  String
  name        String
  code        String   @unique
  bodyPart    String
  price       Decimal  @db.Decimal(10, 2)
  preparation String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  modality   Modality             @relation(fields: [modalityId], references: [id])
  orderItems RadiologyOrderItem[]

  @@map("radiology_exam_types")
}

model RadiologyOrder {
  id             String      @id @default(cuid())
  orderNo        String      @unique
  patientId      String
  consultationId String?
  admissionId    String?
  orderedBy      String
  priority       String      @default("ROUTINE")
  status         OrderStatus @default(PENDING)
  clinicalInfo   String?
  notes          String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  patient      Patient       @relation(fields: [patientId], references: [id])
  consultation Consultation? @relation(fields: [consultationId], references: [id])
  admission    Admission?    @relation(fields: [admissionId], references: [id])

  items RadiologyOrderItem[]

  @@index([patientId])
  @@index([status])
  @@map("radiology_orders")
}

model RadiologyOrderItem {
  id               String      @id @default(cuid())
  radiologyOrderId String
  examTypeId       String
  status           OrderStatus @default(PENDING)
  findings         String?
  impression       String?
  conclusion       String?
  imagePaths       String?
  performedBy      String?
  performedAt      DateTime?
  reportedBy       String?
  reportedAt       DateTime?
  notes            String?

  radiologyOrder RadiologyOrder    @relation(fields: [radiologyOrderId], references: [id], onDelete: Cascade)
  examType       RadiologyExamType @relation(fields: [examTypeId], references: [id])

  @@map("radiology_order_items")
}

// ===========================
// INVENTORY / STORE MANAGEMENT
// ===========================

model InventoryCategory {
  id       String              @id @default(cuid())
  name     String              @unique
  parentId String?
  parent   InventoryCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children InventoryCategory[] @relation("CategoryHierarchy")
  items    InventoryItem[]
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@map("inventory_categories")
}

model InventoryItem {
  id            String   @id @default(cuid())
  name          String
  sku           String   @unique
  categoryId    String
  description   String?
  unit          String
  unitPrice     Decimal  @db.Decimal(10, 2)
  stockQuantity Int      @default(0)
  reorderLevel  Int      @default(10)
  location      String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  category     InventoryCategory   @relation(fields: [categoryId], references: [id])
  transactions StockTransaction[]
  poItems      PurchaseOrderItem[]

  @@index([name])
  @@map("inventory_items")
}

model Supplier {
  id            String   @id @default(cuid())
  name          String
  contactPerson String?
  email         String?
  phone         String
  address       String?
  taxId         String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  purchaseOrders PurchaseOrder[]

  @@map("suppliers")
}

model PurchaseOrder {
  id           String              @id @default(cuid())
  poNumber     String              @unique
  supplierId   String
  status       PurchaseOrderStatus @default(DRAFT)
  totalAmount  Decimal             @db.Decimal(12, 2)
  notes        String?
  orderedBy    String
  approvedBy   String?
  receivedBy   String?
  orderedAt    DateTime            @default(now())
  expectedDate DateTime?
  receivedAt   DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  supplier Supplier            @relation(fields: [supplierId], references: [id])
  items    PurchaseOrderItem[]

  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String  @id @default(cuid())
  purchaseOrderId String
  itemId          String
  quantity        Int
  unitPrice       Decimal @db.Decimal(10, 2)
  totalPrice      Decimal @db.Decimal(12, 2)
  receivedQty     Int     @default(0)

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  item          InventoryItem @relation(fields: [itemId], references: [id])

  @@map("purchase_order_items")
}

model StockTransaction {
  id          String   @id @default(cuid())
  itemId      String
  type        String
  quantity    Int
  reference   String?
  reason      String?
  performedBy String
  createdAt   DateTime @default(now())

  item InventoryItem @relation(fields: [itemId], references: [id])

  @@map("stock_transactions")
}

// ===========================
// HR & PAYROLL
// ===========================

model Employee {
  id             String    @id @default(cuid())
  userId         String    @unique
  employeeNo     String    @unique
  departmentId   String
  designation    String
  dateOfJoining  DateTime
  dateOfLeaving  DateTime?
  employmentType String    @default("FULL_TIME")
  salary         Decimal   @db.Decimal(12, 2)
  bankName       String?
  bankAccountNo  String?
  bankIfsc       String?
  panNumber      String?
  aadharNumber   String?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user       User       @relation(fields: [userId], references: [id])
  department Department @relation(fields: [departmentId], references: [id])

  attendance    Attendance[]
  leaveRequests LeaveRequest[]
  payslips      Payslip[]

  @@map("employees")
}

model Attendance {
  id          String    @id @default(cuid())
  employeeId  String
  date        DateTime
  checkIn     DateTime?
  checkOut    DateTime?
  status      String    @default("PRESENT")
  hoursWorked Decimal?  @db.Decimal(4, 2)
  notes       String?

  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, date])
  @@map("attendance")
}

model LeaveRequest {
  id         String      @id @default(cuid())
  employeeId String
  leaveType  String
  startDate  DateTime
  endDate    DateTime
  totalDays  Int
  reason     String
  status     LeaveStatus @default(PENDING)
  approvedBy String?
  notes      String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])

  @@map("leave_requests")
}

model PayrollRun {
  id          String        @id @default(cuid())
  month       Int
  year        Int
  status      PayrollStatus @default(DRAFT)
  totalAmount Decimal       @db.Decimal(14, 2)
  processedBy String?
  processedAt DateTime?
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  payslips Payslip[]

  @@unique([month, year])
  @@map("payroll_runs")
}

model Payslip {
  id           String  @id @default(cuid())
  payrollRunId String
  employeeId   String
  basicSalary  Decimal @db.Decimal(12, 2)
  allowances   Decimal @db.Decimal(12, 2) @default(0)
  deductions   Decimal @db.Decimal(12, 2) @default(0)
  tax          Decimal @db.Decimal(12, 2) @default(0)
  netSalary    Decimal @db.Decimal(12, 2)
  workingDays  Int
  presentDays  Int
  leaveDays    Int     @default(0)
  overtime     Decimal @db.Decimal(12, 2) @default(0)
  notes        String?

  payrollRun PayrollRun @relation(fields: [payrollRunId], references: [id])
  employee   Employee   @relation(fields: [employeeId], references: [id])

  @@unique([payrollRunId, employeeId])
  @@map("payslips")
}

// ===========================
// AUDIT LOG
