FROM node:20-alpine
RUN apk add --no-cache openssl
WORKDIR /app

COPY package.json package-lock.json* ./
COPY prisma ./prisma/
RUN npm ci
RUN npx prisma generate

COPY tsconfig.json ./
COPY src ./src/

CMD ["sh", "-c", "npx prisma db push --skip-generate && npx prisma db seed && echo '=== Migration and seed complete ==='"]
